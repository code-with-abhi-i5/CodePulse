generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                  String            @id @default(uuid())
  githubId            String            @unique
  username            String            @unique
  name                String?
  avatar              String?
  bio                 String?
  location            String?
  company             String?
  website             String?
  githubUrl           String?
  isOnline            Boolean           @default(false)
  socialLinks         Json?
  joinedAt            DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  deletedAt           DateTime?
  activities          Activity[]
  battlesAsChallenger Battle[]          @relation("BattleChallenger")
  battlesAsOpponent   Battle[]          @relation("BattleOpponent")
  wonBattles          Battle[]          @relation("BattleWinner")
  rating              DeveloperRating?
  stats               DeveloperStats?
  following           Follows[]         @relation("follower")
  followers           Follows[]         @relation("following")
  languages           LanguageStat[]
  notifications       Notification[]
  repositories        Repository[]
  achievements        UserAchievement[]
  badges              UserBadge[]
  challenges          UserChallenge[]

  @@map("users")
}

model Follows {
  followerId  String
  followingId String
  createdAt   DateTime @default(now())
  follower    User     @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("following", fields: [followingId], references: [id], onDelete: Cascade)

  @@id([followerId, followingId])
  @@map("follows")
}

model DeveloperRating {
  id              String   @id @default(uuid())
  userId          String   @unique
  overall         Float    @default(0)
  level           Int      @default(1)
  xp              Int      @default(0)
  xpToNextLevel   Int      @default(100)
  rank            Int      @default(0)
  totalDevelopers Int      @default(0)
  tier            Tier     @default(BRONZE)
  growthScore     Float    @default(0)
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("developer_ratings")
}

model DeveloperStats {
  id               String   @id @default(uuid())
  userId           String   @unique
  totalCommits     Int      @default(0)
  totalPRs         Int      @default(0)
  totalIssues      Int      @default(0)
  totalReviews     Int      @default(0)
  totalStars       Int      @default(0)
  totalForks       Int      @default(0)
  totalRepos       Int      @default(0)
  followers        Int      @default(0)
  following        Int      @default(0)
  contributions    Int      @default(0)
  streak           Int      @default(0)
  longestStreak    Int      @default(0)
  avgCommitsPerDay Float    @default(0)
  activeDays       Int      @default(0)
  updatedAt        DateTime @updatedAt
  contributionData Json?
  commitActivity   Json?
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("developer_stats")
}

model Repository {
  id            String   @id @default(uuid())
  githubRepoId  String   @unique
  userId        String
  name          String
  fullName      String
  description   String?
  language      String?
  languageColor String?
  stars         Int      @default(0)
  forks         Int      @default(0)
  watchers      Int      @default(0)
  issues        Int      @default(0)
  pullRequests  Int      @default(0)
  commits       Int      @default(0)
  contributors  Int      @default(0)
  size          Int      @default(0)
  topics        String[] @default([])
  isPrivate     Boolean  @default(false)
  url           String
  repoCreatedAt DateTime
  repoUpdatedAt DateTime
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("repositories")
}

model LanguageStat {
  id          String  @id @default(uuid())
  userId      String
  name        String
  color       String?
  percentage  Float   @default(0)
  linesOfCode Int     @default(0)
  repos       Int     @default(0)
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@map("language_stats")
}

model Challenge {
  id          String          @id @default(uuid())
  title       String
  description String
  type        ChallengeType
  difficulty  Difficulty
  xpReward    Int
  target      Int
  icon        String?
  category    String?
  expiresAt   DateTime
  createdAt   DateTime        @default(now())
  users       UserChallenge[]

  @@map("challenges")
}

model UserChallenge {
  id          String    @id @default(uuid())
  userId      String
  challengeId String
  progress    Int       @default(0)
  isCompleted Boolean   @default(false)
  completedAt DateTime?
  challenge   Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, challengeId])
  @@map("user_challenges")
}

model Achievement {
  id          String            @id @default(uuid())
  title       String
  description String
  icon        String?
  category    String?
  rarity      Rarity
  target      Int
  xpReward    Int
  users       UserAchievement[]

  @@map("achievements")
}

model UserAchievement {
  id            String      @id @default(uuid())
  userId        String
  achievementId String
  progress      Int         @default(0)
  isUnlocked    Boolean     @default(false)
  unlockedAt    DateTime?
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@map("user_achievements")
}

model Badge {
  id          String      @id @default(uuid())
  name        String
  description String
  icon        String?
  tier        BadgeTier
  category    String?
  users       UserBadge[]

  @@map("badges")
}

model UserBadge {
  id       String   @id @default(uuid())
  userId   String
  badgeId  String
  earnedAt DateTime @default(now())
  badge    Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@map("user_badges")
}

model Battle {
  id              String       @id @default(uuid())
  challengerId    String
  opponentId      String
  status          BattleStatus @default(PENDING)
  category        String
  challengerScore Float?
  opponentScore   Float?
  startedAt       DateTime     @default(now())
  endsAt          DateTime
  winnerId        String?
  challenger      User         @relation("BattleChallenger", fields: [challengerId], references: [id])
  opponent        User         @relation("BattleOpponent", fields: [opponentId], references: [id])
  winner          User?        @relation("BattleWinner", fields: [winnerId], references: [id])

  @@map("battles")
}

model Activity {
  id          String       @id @default(uuid())
  userId      String
  type        ActivityType
  title       String
  description String
  repository  String?
  metadata    Json?
  createdAt   DateTime     @default(now())
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("activities")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  actionUrl String?
  icon      String?
  metadata  Json?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

enum Tier {
  BRONZE
  SILVER
  GOLD
  PLATINUM
  DIAMOND
  MASTER
  GRANDMASTER
}

enum ChallengeType {
  DAILY
  WEEKLY
  MONTHLY
  SEASONAL
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
  LEGENDARY
}

enum Rarity {
  COMMON
  RARE
  EPIC
  LEGENDARY
}

enum BadgeTier {
  BRONZE
  SILVER
  GOLD
  PLATINUM
  DIAMOND
}

enum BattleStatus {
  PENDING
  ACTIVE
  COMPLETED
  CANCELLED
}

enum NotificationType {
  ACHIEVEMENT
  CHALLENGE
  BATTLE
  FRIEND
  SYSTEM
  LEVEL_UP
}

enum ActivityType {
  COMMIT
  PULL_REQUEST
  ISSUE
  REVIEW
  STAR
  FORK
  ACHIEVEMENT
  LEVEL_UP
}
